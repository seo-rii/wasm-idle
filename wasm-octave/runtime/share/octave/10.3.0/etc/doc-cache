                  [2,1] =  3
                  [1,2] =  2
                  [2,2] =  4
                }
          ## all rows (dim 1) of A appear in each element of C
          num2cell (x, 1)
             ⇒
                {
                  [1,1] =
                     1
                     3
                  [1,2] =
                     2
                     4
                }
          ## all columns (dim 2) of A appear in each element of C
          num2cell (x, 2)
             ⇒
                {
                  [1,1] =
                     1   2
                  [2,1] =
                     3   4
                }
          ## all rows and cols appear in each element of C
          ## (hence, only 1 output)
          num2cell (x, [1, 2])
             ⇒
                {
                  [1,1] =
                     1   2
                     3   4
