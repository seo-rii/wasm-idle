{
	"compilerOptions": {
		"allowJs": true,
		"checkJs": true,
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"module": "ESNext",
		"moduleResolution": "bundler",
		"skipLibCheck": true,
		"sourceMap": true,
		"strict": true,
		"target": "ES2022",
		"types": ["node", "vite/client"]
	},
	"include": ["src/**/*.ts", "src/**/*.svelte", "test/**/*.ts", "*.ts", "*.js"]
}
