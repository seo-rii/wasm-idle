{
	"name": "@wasm-idle/terminal",
	"version": "0.1.0",
	"description": "Svelte terminal component for wasm-idle playground bindings",
	"license": "MIT",
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"svelte": "./dist/index.js",
			"import": "./dist/index.js",
			"default": "./dist/index.js"
		}
	},
	"svelte": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"files": [
		"dist"
	],
	"publishConfig": {
		"access": "public"
	},
	"peerDependencies": {
		"@wasm-idle/core": "0.1.0",
		"svelte": "^5.0.0"
	},
	"dependencies": {
		"@wasm-idle/core": "workspace:*",
		"@xterm/addon-fit": "^0.11.0",
		"@xterm/addon-search": "^0.16.0",
		"@xterm/addon-serialize": "^0.14.0",
		"@xterm/addon-unicode11": "^0.9.0",
		"@xterm/addon-web-links": "^0.12.0",
		"@xterm/addon-webgl": "^0.19.0",
		"@xterm/xterm": "^6.0.0"
	},
	"devDependencies": {
		"@sveltejs/package": "^2.5.7",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@types/node": "^25.6.0",
		"playwright-core": "^1.59.1",
		"publint": "^0.3.18",
		"svelte": "^5.55.4",
		"svelte-check": "^4.4.6",
		"typescript": "^5.9.3",
		"vite": "^8.0.8",
		"vitest": "^4.1.4"
	},
	"scripts": {
		"build": "svelte-package --input src --output dist --tsconfig ./tsconfig.json",
		"check": "svelte-check --tsconfig ./tsconfig.json",
		"test": "vitest run --config vitest.config.ts",
		"lint:package": "pnpm run build && publint",
		"prepack": "pnpm run build"
	}
}
