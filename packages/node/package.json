{
	"name": "@wasm-idle/node",
	"version": "0.1.0",
	"description": "Node.js host helpers for wasm-idle core",
	"license": "MIT",
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
