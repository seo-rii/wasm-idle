{
	"name": "@wasm-idle/clang-common",
	"version": "0.1.0",
	"description": "Shared browser Clang compatibility helpers for wasm-idle",
	"license": "MIT",
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"default": "./dist/index.js"
		},
		"./gcc-compat": {
			"types": "./dist/gcc-compat.d.ts",
			"import": "./dist/gcc-compat.js",
			"default": "./dist/gcc-compat.js"
		},
		"./apply": {
			"types": "./dist/apply.d.ts",
			"import": "./dist/apply.js",
			"default": "./dist/apply.js"
		},
		"./color": {
			"types": "./dist/color.d.ts",
			"import": "./dist/color.js",
			"default": "./dist/color.js"
		},
		"./encode": {
			"types": "./dist/encode.d.ts",
			"import": "./dist/encode.js",
			"default": "./dist/encode.js"
		},
		"./error": {
			"types": "./dist/error.d.ts",
			"import": "./dist/error.js",
			"default": "./dist/error.js"
		},
		"./json-stream": {
			"types": "./dist/json-stream.d.ts",
			"import": "./dist/json-stream.js",
			"default": "./dist/json-stream.js"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "rm -rf dist && tsc -p tsconfig.json",
		"check": "tsc -p tsconfig.json --noEmit",
		"test": "vitest run"
	},
	"devDependencies": {
		"typescript": "^6.0.2",
		"vitest": "^4.1.4"
	}
}
