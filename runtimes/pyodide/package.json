{
	"name": "@wasm-idle/runtime-pyodide",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"description": "Pyodide runtime asset and loader helpers for wasm-idle",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"default": "./dist/index.js"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "rm -rf dist && tsc -p tsconfig.json",
		"check": "tsc -p tsconfig.json --noEmit"
	},
	"devDependencies": {
		"pyodide": "0.29.3",
		"typescript": "^6.0.2"
	}
}
