{
	"name": "@wasm-idle/runtime-kotlin",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"description": "Kotlin/Wasm build and asset helpers for wasm-idle",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"default": "./dist/index.js"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "rm -rf dist && tsc -p tsconfig.json",
		"check": "tsc -p tsconfig.json --noEmit"
	},
	"dependencies": {
		"kotlin-web-helpers": "3.1.0"
	},
	"devDependencies": {
		"typescript": "^6.0.2"
	}
}
