{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "WebWorker"],
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "strict": true,
    "exactOptionalPropertyTypes": true,
    "noUncheckedIndexedAccess": true,
    "skipLibCheck": true,
    "outDir": "browser-harness/dist",
    "rootDir": "."
  },
  "include": ["browser-harness/**/*.ts", "runtime/**/*.ts", "src/**/*.ts"]
}
