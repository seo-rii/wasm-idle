{
  "name": "wasm-go",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Browser-loadable Go compiler runtime scaffolding for WebAssembly",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "default": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json && node ./scripts/finalize-browser-bundle.mjs",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "prepare:runtime": "node ./scripts/prepare-runtime.mjs",
    "probe:runtime": "node ./scripts/probe-runtime.mjs",
    "validate:runtime": "npm run build && npm run prepare:runtime && npm run probe:runtime"
  },
  "dependencies": {
    "@bjorn3/browser_wasi_shim": "^0.4.2"
  },
  "devDependencies": {
    "@types/node": "^24.6.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18",
    "wabt": "^1.0.39"
  }
}
