{
	"name": "wasm-lisp",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"description": "Browser-loadable Scheme compiler module for wasm-idle",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"default": "./dist/index.js"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "rm -rf dist && tsc -p tsconfig.json && node ./scripts/prepare-runtime.mjs",
		"check": "tsc -p tsconfig.json --noEmit",
		"test": "pnpm run build && vitest run"
	},
	"dependencies": {
		"@bytecodealliance/jco": "^1.19.0",
		"@bytecodealliance/preview2-shim": "^0.17.9"
	},
	"devDependencies": {
		"@types/node": "^24.6.1",
		"typescript": "^5.9.3",
		"vitest": "^4.0.18"
	}
}
