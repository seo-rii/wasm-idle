{
	"name": "wasm-rust",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"description": "Browser-loadable Rust compiler module for wasm-idle",
	"exports": {
		".": {
			"import": "./dist/index.js",
			"default": "./dist/index.js",
			"types": "./dist/index.d.ts"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "pnpm run build:js && pnpm run prepare:runtime",
		"build:all-compressed": "WASM_RUST_PRECOMPRESS_SCOPES=all pnpm run build",
		"build:js": "tsc -p tsconfig.json",
		"build:producer": "pnpm run build:js && pnpm run prepare:runtime:producer",
		"build:prebuilt": "WASM_RUST_ALLOW_PREBUILT_RUNTIME_FALLBACK=1 pnpm run build",
		"build:uncompressed": "WASM_RUST_PRECOMPRESS_SCOPES=none pnpm run build",
		"prepare:runtime": "node scripts/prepare-runtime.mjs",
		"prepare:runtime:producer": "node scripts/prepare-producer-runtime.mjs",
		"prepare:runtime:all-compressed": "WASM_RUST_PRECOMPRESS_SCOPES=all node scripts/prepare-runtime.mjs",
		"prepare:runtime:uncompressed": "WASM_RUST_PRECOMPRESS_SCOPES=none node scripts/prepare-runtime.mjs",
		"prepare:runtime:wasip2": "bash ./scripts/prepare-wasip2-runtime.sh",
		"prepare:runtime:wasip2:probe": "bash ./scripts/prepare-wasip2-runtime.sh --probe",
		"prepare:runtime:wasip3": "bash ./scripts/prepare-wasip3-runtime.sh",
		"prepare:runtime:wasip3:probe": "bash ./scripts/prepare-wasip3-runtime.sh --probe",
		"toolchain:prepare:wasip3-source": "bash ./scripts/prepare-wasip3-rust-source.sh",
		"toolchain:prepare:wasip3-libc": "bash ./scripts/prepare-wasip3-libc-overlay.sh",
		"toolchain:build:custom": "bash ./scripts/build-custom-rustc-toolchain.sh",
		"toolchain:build:custom:wasip3": "WASM_RUST_INSTALL_TARGETS=x86_64-unknown-linux-gnu,wasm32-wasip1,wasm32-wasip2,wasm32-wasip3 bash ./scripts/build-custom-rustc-toolchain.sh",
		"toolchain:bootstrap:wasip3": "WASM_RUST_INSTALL_TARGETS=x86_64-unknown-linux-gnu,wasm32-wasip1,wasm32-wasip2,wasm32-wasip3 bash ./scripts/bootstrap-wasip3-toolchain.sh",
		"toolchain:watch:custom": "node ./scripts/watch-process.mjs",
		"release:upload": "bash ./scripts/upload-github-asset.sh",
		"check": "pnpm run typecheck",
		"typecheck": "pnpm exec tsc -p tsconfig.json --noEmit",
		"test": "vitest run",
		"test:ci": "pnpm run test:ci:fast",
		"test:ci:fast": "WASM_RUST_SKIP_DIST_TESTS=1 pnpm exec vitest run test/artifact.test.ts test/asset-url.test.ts test/browser-component-tools.test.ts test/browser-execution.test.ts test/browser-linker.test.ts test/build-output.test.ts test/ci-script-contract.test.ts test/compiler-edge-cases.test.ts test/compiler-progress.test.ts test/compiler-retry.test.ts test/compiler-worker.test.ts test/diagnostics.test.ts test/fixtures.test.ts test/index.test.ts test/module-worker.test.ts test/producer-runtime.test.ts test/runtime-bitcode-mirror.test.ts test/runtime-compression-config.test.ts test/runtime-manifest-edge.test.ts test/runtime-pack.test.ts test/runtime-random.test.ts test/rustc-runtime.test.ts test/shared-workspace.test.ts test/thread-startup.test.ts test/validate-standalone-browser.test.ts test/wasip3-build-pipeline.test.ts test/watch-process.test.ts test/worker-status.test.ts",
		"test:ci:browser": "pnpm run test:browser && pnpm run test:browser:vitest && pnpm run test:browser:playwright",
		"test:ci:browser:clean-room": "pnpm run build:js && pnpm run probe:browser-harness && pnpm run test:browser:vitest && pnpm run test:browser:playwright",
		"test:browser": "pnpm build && node ./scripts/probe-browser-harness.mjs",
		"test:browser:vitest": "WASM_RUST_RUN_REAL_BROWSER_HARNESS=1 pnpm exec vitest run test/browser-harness.test.ts",
		"test:browser:playwright": "WASM_RUST_RUN_REAL_BROWSER_HARNESS=1 pnpm exec vitest run test/browser-playwright-integration.test.ts",
		"validate:standalone-browser": "node ./scripts/validate-standalone-browser.mjs",
		"serve:browser-harness": "node ./scripts/browser-harness-server.mjs",
		"probe:native-link": "node scripts/probe-native-rust-link.mjs",
		"probe:native-link:wasip1": "WASM_RUST_NATIVE_TARGET_TRIPLES=wasm32-wasip1 node scripts/probe-native-rust-link.mjs",
		"probe:native-link:wasip2": "WASM_RUST_NATIVE_TARGET_TRIPLES=wasm32-wasip2 node scripts/probe-native-rust-link.mjs",
		"probe:native-link:wasip3": "WASM_RUST_NATIVE_TARGET_TRIPLES=wasm32-wasip3 node scripts/probe-native-rust-link.mjs",
		"probe:browser-harness": "node ./scripts/probe-browser-harness.mjs",
		"probe:rustc": "node scripts/probe-rustc-wasm.mjs",
		"probe:browser-clang-rust-split": "node --loader ./scripts/node-js-extension-loader.mjs ./scripts/probe-browser-clang-rust-split.mjs",
		"probe:browser-rustc-llvm-wasm-split": "node ./scripts/probe-browser-rustc-llvm-wasm-split.mjs",
		"probe:llvm-wasm-rust-split": "node ./scripts/probe-llvm-wasm-rust-split.mjs",
		"probe:rustc:real-threads": "WASM_RUST_REAL_THREADS=1 node scripts/probe-rustc-wasm.mjs",
		"probe:rustc:llvm-backend": "WASM_RUST_CODEGEN_BACKEND=llvm node scripts/probe-rustc-wasm.mjs",
		"probe:rustc:llvm-backend:real-threads": "WASM_RUST_REAL_THREADS=1 WASM_RUST_CODEGEN_BACKEND=llvm node scripts/probe-rustc-wasm.mjs",
		"probe:rustc:link-attempt": "WASM_RUST_PROBE_MODE=link_attempt node scripts/probe-rustc-wasm.mjs",
		"probe:rustc:patched-target": "node scripts/probe-rustc-wasm.mjs --patch-target-metadata"
	},
	"devDependencies": {
		"@types/node": "^24.6.1",
		"playwright-core": "^1.58.2",
		"typescript": "^5.9.3",
		"vitest": "^4.0.18",
		"wabt": "^1.0.39"
	},
	"dependencies": {
		"@bjorn3/browser_wasi_shim": "^0.4.2",
		"@bytecodealliance/jco": "^1.17.3",
		"@bytecodealliance/preview2-shim": "^0.17.8"
	}
}
