{
	"name": "@wasm-idle/runtime-assemblyscript",
	"version": "0.1.0",
	"type": "module",
	"description": "AssemblyScript compiler and loader helpers for wasm-idle",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"default": "./dist/index.js"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "rm -rf dist && tsc -p tsconfig.json",
		"check": "tsc -p tsconfig.json --noEmit"
	},
	"dependencies": {
		"@assemblyscript/loader": "0.28.17",
		"assemblyscript": "0.28.17"
	},
	"devDependencies": {
		"typescript": "^6.0.2"
	}
}
