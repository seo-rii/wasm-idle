{
	"compilerOptions": {
		"target": "ES2022",
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"lib": ["ES2022", "DOM", "WebWorker"],
		"strict": true,
		"declaration": true,
		"sourceMap": true,
		"declarationMap": true,
		"outDir": "dist",
		"rootDir": ".",
		"skipLibCheck": true
	},
	"include": ["src/**/*.ts"]
}
