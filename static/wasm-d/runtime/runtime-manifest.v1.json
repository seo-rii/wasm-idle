{
  "manifestVersion": 1,
  "name": "wasm-d",
  "version": "ldc-1.42.0-wasi-smoke",
  "defaultTarget": "wasm32-wasi",
  "compiler": {
    "ldc2": {
      "asset": "bin/ldc2.wasm",
      "argv0": "ldc2"
    },
    "toolchain": {
      "asset": "toolchain/toolchain.tar"
    },
    "linker": {
      "kind": "emscripten-lld",
      "argv0": "wasm-ld",
      "js": {
        "asset": "bin/lld.js"
      },
      "wasm": {
        "asset": "bin/lld.wasm"
      },
      "data": {
        "asset": "bin/lld.data"
      }
    }
  },
  "targets": {
    "wasm32-wasi": {
      "artifactFormat": "wasi-core-wasm",
      "execution": {
        "kind": "wasi-preview1"
      }
    }
  }
}
